# Shared service authentication
FLEXI_SERVICE_TOKEN=replace-me
FOUNDATION_API_BASE=http://127.0.0.1:4010

# Local preview databases. PGlite is development-only.
FLEXI_DB_DIR=.data/local-foundation-pglite
FLEXI_OPS_DB_DIR=.data/local-ops-pglite

# Bolt fleet connector
BOLT_LAGOS_CLIENT_ID=
BOLT_LAGOS_CLIENT_SECRET=
BOLT_LAGOS_COMPANY_ID=168098

# Uber ride-hailing account
UBER_CLIENT_ID_1=
UBER_CLIENT_SECRET_1=
UBER_ORG_ID_ENCRYPTED_1=

# Uber courier account
UBER_CLIENT_ID_2=
UBER_CLIENT_SECRET_2=
UBER_ORG_ID_ENCRYPTED_2=

# Notification routing. Required when NODE_ENV=production.
OPS_NOTIFICATION_WEBHOOK_URL=
OPS_NOTIFICATION_WEBHOOK_TOKEN=

# Runtime tuning
OPS_WORKER_POLL_MS=5000

# Payments / Monnify integration. Use simulated locally, sandbox with Monnify
# sandbox credentials, and production only after Monnify approval.
MONNIFY_PROVIDER_MODE=simulated
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_WEBHOOK_SECRET=
OPS_API_BASE=http://127.0.0.1:4030
FLEXI_PAYMENTS_DB_DIR=.data/local-payments-pglite
