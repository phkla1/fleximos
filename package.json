{
  "name": "fleximos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "FLEXI_DB_DIR=.data/local-foundation-pglite node apps/api-foundation/server.mjs",
    "dev:ops-api": "PORT=4030 FLEXI_OPS_DB_DIR=.data/local-ops-pglite tsx apps/ops-api/src/main.ts",
    "dev:payments-api": "PORT=4040 FLEXI_PAYMENTS_DB_DIR=.data/local-payments-pglite node apps/payments-integration/server.mjs",
    "dev:payments-api:sandbox": "PORT=4040 MONNIFY_PROVIDER_MODE=sandbox FLEXI_PAYMENTS_DB_DIR=.data/local-payments-pglite node apps/payments-integration/server.mjs",
    "dev:ops-worker": "FLEXI_OPS_DB_DIR=.data/local-ops-pglite tsx apps/ops-api/src/worker.ts",
    "dev:ops-scheduler": "FLEXI_OPS_DB_DIR=.data/local-ops-pglite tsx apps/ops-api/src/scheduler.ts",
    "ops:worker:once": "FLEXI_OPS_DB_DIR=.data/local-ops-pglite tsx apps/ops-api/src/worker.ts --once",
    "ops:scheduler:once": "FLEXI_OPS_DB_DIR=.data/local-ops-pglite tsx apps/ops-api/src/scheduler.ts --once",
    "dev:portal": "node scripts/serve-developer-portal.mjs",
    "seed:ops-demo": "node scripts/seed-ops-demo.mjs",
    "migrate:ops-daily": "node scripts/migrate-ops-daily-csv.mjs",
    "test:api": "node --test tests/api/*.test.mjs",
    "validate:openapi": "node scripts/validate-openapi.mjs",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.1",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}
