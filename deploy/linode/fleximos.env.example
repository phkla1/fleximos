# Copy to /etc/fleximos/fleximos.env and adjust before starting the services.
# Everything here is read by the systemd units via EnvironmentFile=.

# Shared service-to-service bearer token. CHANGE THIS for any server that is
# reachable from the internet — it grants unrestricted service access.
FLEXI_SERVICE_TOKEN=change-me-to-a-long-random-string

# Monnify provider mode: "simulated" needs no external account;
# "sandbox" requires real Monnify sandbox credentials.
MONNIFY_PROVIDER_MODE=simulated
# MONNIFY_API_KEY=
# MONNIFY_SECRET_KEY=
# MONNIFY_CONTRACT_CODE=

# Media policy. Keep lenient for UAT; tighten for production.
MEDIA_STRICT_CAPTURE=false
MEDIA_REQUIRE_GPS=false
MEDIA_CAPTURE_TOLERANCE_MINUTES=5

# Manager escalation window for unacknowledged high-severity incidents.
INCIDENT_ESCALATION_MINUTES=30
