{
  "openapi": "3.1.0",
  "info": {
    "title": "Fleximotion Payments Integration API",
    "version": "1.0.0",
    "description": "Provider-facing boundary for Monnify reserved accounts, verified deposit events, webhook evidence, and scheduled reconciliation. Ops remains the canonical owner of operator financial position."
  },
  "servers": [
    {
      "url": "https://api.fleximotion.example/payments/v1",
      "description": "Production placeholder"
    },
    {
      "url": "http://127.0.0.1:4040/payments/v1",
      "description": "Local development"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Reserved Accounts"
    },
    {
      "name": "Webhooks"
    },
    {
      "name": "Transactions"
    },
    {
      "name": "Reconciliation"
    }
  ],
  "paths": {
    "/operators/{operator_id}/reserved-account": {
      "get": {
        "tags": [
          "Reserved Accounts"
        ],
        "summary": "Get an operator reserved account",
        "parameters": [
          {
            "$ref": "#/components/parameters/OperatorId"
          }
        ],
        "responses": {
          "200": {
            "description": "Reserved account mapping",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReservedAccount"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "post": {
        "tags": [
          "Reserved Accounts"
        ],
        "summary": "Provision an operator reserved account",
        "description": "Creates or safely replays a Monnify customer reserved-account request. Requires service, owner/admin, or scoped Finance authority. BVN or NIN is handled through an encrypted KYC workflow and must never be written to application logs.",
        "parameters": [
          {
            "$ref": "#/components/parameters/OperatorId"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProvisionReservedAccountRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Reserved account provisioned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReservedAccount"
                }
              }
            }
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/reserved-accounts": {
      "get": {
        "tags": [
          "Reserved Accounts"
        ],
        "summary": "List reserved accounts",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "pending",
                "active",
                "restricted",
                "deallocated",
                "failed"
              ]
            }
          },
          {
            "name": "amoeba_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Reserved accounts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "data"
                  ],
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ReservedAccount"
                      }
                    },
                    "next_cursor": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/webhooks/monnify": {
      "post": {
        "tags": [
          "Webhooks"
        ],
        "summary": "Receive a Monnify webhook",
        "description": "Public provider callback authenticated with Monnify's signature. The raw body is preserved before processing, then the transaction is verified and deduplicated before a normalized event is delivered to Ops.",
        "security": [],
        "parameters": [
          {
            "name": "monnify-signature",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Provider signature header. The implementation must use the exact header and algorithm specified by the active Monnify webhook documentation."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Webhook evidence accepted for verification"
          },
          "401": {
            "description": "Invalid provider signature"
          }
        }
      }
    },
    "/webhook-events": {
      "get": {
        "tags": [
          "Webhooks"
        ],
        "summary": "List webhook processing evidence",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "received",
                "verified",
                "matched",
                "delivered",
                "rejected",
                "quarantined"
              ]
            }
          },
          {
            "name": "operator_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook evidence",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "data"
                  ],
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/WebhookEvent"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/transactions": {
      "get": {
        "tags": [
          "Transactions"
        ],
        "summary": "List verified deposit transactions",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "received",
                "verified",
                "matched",
                "delivered_to_ops",
                "reconciled",
                "settled",
                "finance_approved",
                "quarantined"
              ]
            }
          },
          {
            "name": "operator_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deposit transactions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "data"
                  ],
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/DepositTransaction"
                      }
                    },
                    "next_cursor": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/transactions/{transaction_reference}/verify": {
      "post": {
        "tags": [
          "Transactions"
        ],
        "summary": "Verify and normalize a provider transaction",
        "description": "Fetches the authoritative transaction from Monnify and safely replays matching and delivery to Ops.",
        "parameters": [
          {
            "$ref": "#/components/parameters/TransactionReference"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "responses": {
          "200": {
            "description": "Verified transaction",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DepositTransaction"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/transactions/{transaction_reference}/settle": {
      "post": {
        "tags": [
          "Transactions"
        ],
        "summary": "Mark a reconciled transaction as settled",
        "description": "Requires service, owner/admin, or scoped Finance authority. Manager-scoped users can review transactions but cannot settle them.",
        "parameters": [
          {
            "$ref": "#/components/parameters/TransactionReference"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "notes": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Settled transaction",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DepositTransaction"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/transactions/{transaction_reference}/finance-approve": {
      "post": {
        "tags": [
          "Transactions"
        ],
        "summary": "Finance approve a settled transaction",
        "description": "Requires service, owner/admin, or scoped Finance authority. Manager-scoped users can review transactions but cannot finance-approve them.",
        "parameters": [
          {
            "$ref": "#/components/parameters/TransactionReference"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "notes": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Finance-approved transaction",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DepositTransaction"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/reconciliation-runs": {
      "get": {
        "tags": [
          "Reconciliation"
        ],
        "summary": "List reconciliation runs",
        "responses": {
          "200": {
            "description": "Reconciliation runs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "data"
                  ],
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ReconciliationRun"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Reconciliation"
        ],
        "summary": "Start a provider reconciliation run",
        "description": "Backfills provider transactions for a bounded period and compares them with locally delivered deposits. This endpoint is also invoked by the scheduled reconciliation worker.",
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateReconciliationRunRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Reconciliation queued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReconciliationRun"
                }
              }
            }
          }
        }
      }
    },
    "/accounting-period-closes": {
      "get": {
        "tags": [
          "Reconciliation"
        ],
        "summary": "List accounting period close records",
        "responses": {
          "200": {
            "description": "Accounting period closes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "data"
                  ],
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/AccountingPeriodClose"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Reconciliation"
        ],
        "summary": "Close a bounded accounting period",
        "description": "Creates an audit record that locks the selected accounting period for Ops cash adjustments. Requires service, owner/admin, or scoped Finance authority.",
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAccountingPeriodCloseRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Accounting period close",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountingPeriodClose"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/test/simulate-deposit": {
      "post": {
        "tags": [
          "Transactions"
        ],
        "summary": "Simulate a sandbox reserved-account deposit",
        "description": "Development-only endpoint available when MONNIFY_PROVIDER_MODE=simulated. Requires service, owner/admin, or scoped Finance authority. It exercises the same signed webhook, deduplication, matching, and Ops delivery path used by provider events.",
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "operator_id",
                  "amount_ngn"
                ],
                "properties": {
                  "operator_id": {
                    "type": "string"
                  },
                  "amount_ngn": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "transaction_reference": {
                    "type": "string"
                  },
                  "paid_at": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Simulated deposit accepted"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "Reconciliation"
        ],
        "summary": "Get provider integration health",
        "responses": {
          "200": {
            "description": "Provider, webhook, delivery, and reconciliation freshness"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT or service token"
      }
    },
    "parameters": {
      "OperatorId": {
        "name": "operator_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^operator_"
        }
      },
      "TransactionReference": {
        "name": "transaction_reference",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "IdempotencyKey": {
        "name": "Idempotency-Key",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string",
          "minLength": 8,
          "maxLength": 128
        }
      }
    },
    "schemas": {
      "ProvisionReservedAccountRequest": {
        "type": "object",
        "required": [
          "customer_name",
          "customer_email"
        ],
        "properties": {
          "customer_name": {
            "type": "string"
          },
          "customer_email": {
            "type": "string",
            "format": "email"
          },
          "currency_code": {
            "type": "string",
            "const": "NGN",
            "default": "NGN"
          },
          "kyc_reference": {
            "type": "string",
            "description": "Opaque reference to encrypted BVN or NIN material held by the approved KYC workflow. Raw identity numbers are not accepted by this API."
          }
        }
      },
      "ReservedAccount": {
        "type": "object",
        "required": [
          "reserved_account_id",
          "operator_id",
          "provider",
          "account_reference",
          "status"
        ],
        "properties": {
          "reserved_account_id": {
            "type": "string",
            "pattern": "^reserved_account_"
          },
          "operator_id": {
            "type": "string",
            "pattern": "^operator_"
          },
          "amoeba_id": {
            "type": "string"
          },
          "provider": {
            "type": "string",
            "const": "monnify"
          },
          "account_reference": {
            "type": "string"
          },
          "account_name": {
            "type": "string"
          },
          "bank_name": {
            "type": "string"
          },
          "account_number_masked": {
            "type": "string",
            "description": "Masked for ordinary list responses. Full account number access is separately authorized."
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "active",
              "restricted",
              "deallocated",
              "failed"
            ]
          },
          "kyc_status": {
            "type": "string",
            "enum": [
              "not_required_for_test",
              "pending",
              "verified",
              "failed"
            ]
          },
          "current_balance_ngn": {
            "type": "number",
            "description": "Projected Monnify reserved-account balance available to Finance and Analytics."
          },
          "total_deposits_ngn": {
            "type": "number",
            "description": "Cumulative deposits observed for this reserved account."
          },
          "last_deposit_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "WebhookEvent": {
        "type": "object",
        "required": [
          "webhook_event_id",
          "provider",
          "event_type",
          "status",
          "received_at"
        ],
        "properties": {
          "webhook_event_id": {
            "type": "string",
            "pattern": "^webhook_event_"
          },
          "provider": {
            "type": "string",
            "const": "monnify"
          },
          "event_type": {
            "type": "string"
          },
          "provider_event_reference": {
            "type": "string"
          },
          "transaction_reference": {
            "type": "string"
          },
          "operator_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "received",
              "verified",
              "matched",
              "delivered",
              "rejected",
              "quarantined"
            ]
          },
          "received_at": {
            "type": "string",
            "format": "date-time"
          },
          "processed_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        }
      },
      "DepositTransaction": {
        "type": "object",
        "required": [
          "deposit_transaction_id",
          "provider",
          "transaction_reference",
          "amount",
          "currency",
          "status"
        ],
        "properties": {
          "deposit_transaction_id": {
            "type": "string",
            "pattern": "^deposit_"
          },
          "provider": {
            "type": "string",
            "const": "monnify"
          },
          "transaction_reference": {
            "type": "string"
          },
          "operator_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "amount": {
            "type": "number",
            "minimum": 0
          },
          "currency": {
            "type": "string",
            "const": "NGN"
          },
          "paid_at": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "enum": [
              "received",
              "verified",
              "matched",
              "delivered_to_ops",
              "reconciled",
              "settled",
              "finance_approved",
              "quarantined"
            ]
          }
        }
      },
      "CreateReconciliationRunRequest": {
        "type": "object",
        "required": [
          "period_start",
          "period_end"
        ],
        "properties": {
          "period_start": {
            "type": "string",
            "format": "date-time"
          },
          "period_end": {
            "type": "string",
            "format": "date-time"
          },
          "operator_id": {
            "type": "string"
          }
        }
      },
      "ReconciliationRun": {
        "type": "object",
        "required": [
          "reconciliation_run_id",
          "provider",
          "status",
          "period_start",
          "period_end"
        ],
        "properties": {
          "reconciliation_run_id": {
            "type": "string",
            "pattern": "^reconciliation_"
          },
          "provider": {
            "type": "string",
            "const": "monnify"
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "running",
              "completed",
              "completed_with_exceptions",
              "failed"
            ]
          },
          "period_start": {
            "type": "string",
            "format": "date-time"
          },
          "period_end": {
            "type": "string",
            "format": "date-time"
          },
          "provider_transactions": {
            "type": "integer",
            "minimum": 0
          },
          "matched_transactions": {
            "type": "integer",
            "minimum": 0
          },
          "exceptions": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "CreateAccountingPeriodCloseRequest": {
        "type": "object",
        "required": [
          "period_start",
          "period_end"
        ],
        "properties": {
          "period_start": {
            "type": "string",
            "format": "date-time"
          },
          "period_end": {
            "type": "string",
            "format": "date-time"
          },
          "ops_exception_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Unresolved Ops cash exceptions included in the closeout decision."
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "AccountingPeriodClose": {
        "type": "object",
        "properties": {
          "accounting_period_close_id": {
            "type": "string",
            "pattern": "^period_close_"
          },
          "period_start": {
            "type": "string",
            "format": "date-time"
          },
          "period_end": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "enum": [
              "closed",
              "closed_with_exceptions"
            ]
          },
          "deposit_count": {
            "type": "integer",
            "minimum": 0
          },
          "reconciled_count": {
            "type": "integer",
            "minimum": 0
          },
          "settled_count": {
            "type": "integer",
            "minimum": 0
          },
          "finance_approved_count": {
            "type": "integer",
            "minimum": 0
          },
          "provider_exception_count": {
            "type": "integer",
            "minimum": 0
          },
          "ops_exception_count": {
            "type": "integer",
            "minimum": 0
          },
          "exception_count": {
            "type": "integer",
            "minimum": 0
          },
          "total_amount_ngn": {
            "type": "number"
          },
          "settlement_amount_ngn": {
            "type": "number"
          },
          "closed_by_person_id": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "object",
