        }
      }
    },
    "/role-assignments": {
      "get": {
        "tags": [
          "Role Assignments"
        ],
        "summary": "List scoped business-role assignments",
        "description": "System-admin endpoint. Effective access is the union of every active assignment returned for a person.",
        "parameters": [
          {
            "name": "person_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "role",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "manager",
                "finance",
                "supervisor",
                "operator"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Role assignments",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RoleAssignmentsPage"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      },
      "post": {
        "tags": [
          "Role Assignments"
        ],
        "summary": "Create a scoped business-role assignment",
        "description": "Assigns a role independently of scope. Use multiple assignments when one person needs visibility across several teams, sites, or amoebas.",
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRoleAssignmentRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Role assignment created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RoleAssignment"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/role-assignments/{role_assignment_id}": {
      "patch": {
        "tags": [
          "Role Assignments"
        ],
        "summary": "Update or deactivate a role assignment",
        "parameters": [
          {
            "$ref": "#/components/parameters/RoleAssignmentId"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateRoleAssignmentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Role assignment updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RoleAssignment"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/service-accounts": {
      "get": {
        "tags": [
          "Service Accounts"
        ],
        "summary": "List service accounts",
        "responses": {
          "200": {
            "description": "Service accounts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceAccountsPage"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Service Accounts"
        ],
        "summary": "Create service account",
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateServiceAccountRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Service account",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceAccount"
                }
              }
            }
          }
        }
      }
    },
    "/service-accounts/{service_account_id}/tokens": {
      "post": {
        "tags": [
          "Service Accounts"
        ],
        "summary": "Issue service account token",
        "description": "Returns the raw token once. The API stores only a hash.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ServiceAccountId"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "responses": {
          "201": {
            "description": "Issued token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IssuedServiceAccountToken"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/service-accounts/{service_account_id}/tokens/{token_id}": {
      "delete": {
        "tags": [
          "Service Accounts"
        ],
        "summary": "Revoke service account token",
        "parameters": [
          {
            "$ref": "#/components/parameters/ServiceAccountId"
          },
          {
            "$ref": "#/components/parameters/TokenId"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "responses": {
          "200": {
            "description": "Revoked token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RevokedServiceAccountToken"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT or service token"
      }
    },
    "parameters": {
      "Limit": {
        "name": "limit",
        "in": "query",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200,
          "default": 50
        }
      },
      "Cursor": {
        "name": "cursor",
        "in": "query",
        "schema": {
          "type": "string"
        }
      },
      "IdempotencyKey": {
        "name": "Idempotency-Key",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string",
          "minLength": 8,
          "maxLength": 160
        }
      },
      "PersonId": {
        "name": "person_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^person_"
        }
      },
      "UserId": {
        "name": "user_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^user_"
        }
      },
      "RoleAssignmentId": {
        "name": "role_assignment_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^roleasg_"
        }
      },
      "ServiceAccountId": {
        "name": "service_account_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^svc_"
        }
      },
      "TokenId": {
        "name": "token_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "pattern": "^sat_"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Missing or invalid credentials",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Authenticated actor does not have permission",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Conflict": {
        "description": "Duplicate or conflicting write",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "Person": {
        "type": "object",
        "required": [
          "person_id",
          "display_name",
          "global_status",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "person_id": {
            "type": "string",
            "examples": [
              "person_01JZ7M2Z1T2Q8S4PZ9T6Y0A1BC"
            ]
          },
          "legal_name": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "phone": {
            "type": [
              "string",
              "null"
            ]
          },
          "email": {
            "type": [
              "string",
              "null"
            ],
            "format": "email"
          },
          "global_status": {
            "type": "string",
            "enum": [
              "active",
              "inactive",
              "suspended"
            ]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "nin": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^\\d{11}$",
            "description": "Nigerian National Identification Number (11 digits). Collected for Uber/Bolt onboarding; unique per person."
          }
        }
      },
      "CreatePersonRequest": {
        "type": "object",
        "required": [
          "display_name"
        ],
        "properties": {
          "legal_name": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "UpdatePersonRequest": {
        "type": "object",
        "properties": {
          "legal_name": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "phone": {
            "type": [
              "string",
              "null"
            ]
          },
          "email": {
            "type": [
              "string",
              "null"
            ],
            "format": "email"
          },
          "global_status": {
            "type": "string",
            "enum": [
              "active",
              "inactive",
              "suspended"
            ]
          }
        }
      },
      "PeoplePage": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Person"
            }
          },
          "next_cursor": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "User": {
        "type": "object",
        "required": [
          "user_id",
          "person_id",
          "roles",
          "status"
        ],
        "properties": {
          "user_id": {
            "type": "string",
            "examples": [
              "user_01JZ7M34A6JPEP4PV1WQ22RME7"
            ]
          },
          "person_id": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive",
              "suspended"
            ]
          }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "required": [
          "person_id",
          "roles"
        ],
        "properties": {
          "person_id": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "properties": {
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive",
              "suspended"
            ]
          }
        }
      },
      "UsersPage": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/User"
            }
          },
          "next_cursor": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "RoleAssignment": {
        "type": "object",
        "required": [
          "role_assignment_id",
          "person_id",
          "role",
          "scope_type",
          "status",
          "valid_from"
        ],
        "properties": {
          "role_assignment_id": {
            "type": "string"
          },
          "person_id": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "manager",
              "finance",
              "supervisor",
              "operator"
            ]
          },
          "scope_type": {
            "type": "string",
            "enum": [
              "company",
              "amoeba",
              "site",
              "team"
            ]
          },
          "scope_id": {
            "type": [
              "string",
