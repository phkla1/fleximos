{
  "openapi": "3.1.0",
  "info": {
    "title": "Fleximotion Identity API",
    "version": "1.0.0",
    "description": "Canonical people, user accounts, roles, service accounts, and authentication for the Fleximotion app suite."
  },
  "servers": [
    {
      "url": "https://api.fleximotion.example/identity/v1",
      "description": "Production placeholder"
    },
    {
      "url": "http://localhost:4010/v1",
      "description": "Local development"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "People"
    },
    {
      "name": "Users"
    },
    {
      "name": "Role Assignments"
    },
    {
      "name": "Auth"
    },
    {
      "name": "Service Accounts"
    }
  ],
  "paths": {
    "/people": {
      "get": {
        "tags": [
          "People"
        ],
        "summary": "List people",
        "description": "Returns canonical human identity records. Domain systems should reference people by person_id rather than duplicating identity fields.",
        "parameters": [
          {
            "$ref": "#/components/parameters/Limit"
          },
          {
            "$ref": "#/components/parameters/Cursor"
          }
        ],
        "responses": {
          "200": {
            "description": "People page",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PeoplePage"
                },
                "examples": {
                  "default": {
                    "value": {
                      "data": [
                        {
                          "person_id": "person_01JZ7M2Z1T2Q8S4PZ9T6Y0A1BC",
                          "legal_name": "Danjimoh Osheimoh",
                          "display_name": "Danjimoh Osheimoh",
                          "phone": "+2347050599554",
                          "email": null,
                          "global_status": "active",
                          "created_at": "2026-06-04T09:00:00Z",
                          "updated_at": "2026-06-04T09:00:00Z"
                        }
                      ],
                      "next_cursor": null
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "tags": [
          "People"
        ],
        "summary": "Create a person",
        "description": "Creates the canonical human identity record. Clients must send an Idempotency-Key header.",
        "parameters": [
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePersonRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Person created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Person"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/people/{person_id}": {
      "get": {
        "tags": [
          "People"
        ],
        "summary": "Get a person",
        "parameters": [
          {
            "$ref": "#/components/parameters/PersonId"
          }
        ],
        "responses": {
          "200": {
            "description": "Person",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Person"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "patch": {
        "tags": [
          "People"
        ],
        "summary": "Update a person",
        "description": "Updates basic canonical identity fields. Domain-specific lifecycle state belongs in HR, Ops, or TMS.",
        "parameters": [
          {
            "$ref": "#/components/parameters/PersonId"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePersonRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated person",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Person"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/people/{person_id}/history": {
      "get": {
        "tags": [
          "People"
        ],
        "summary": "Get person history",
